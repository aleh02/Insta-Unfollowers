{
  "name": "insta-unfollowers",
  "version": "2.0.0",
  "private": true,
  "description": "Instagram unfollower tracker with Node.js backend and React frontend",
  "main": "insta-unfollowers.js",
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "vite --config client/vite.config.mjs",
    "dev": "concurrently -n server,client -c green,blue \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build --config client/vite.config.mjs",
    "start": "NODE_ENV=production node server/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "express": "^4.19.2",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "vite": "^8.1.0"
  }
}
